{
	"log": {
		"level": "info",
		"timestamp": true
	},
	"experimental": {
		"clash_api": {
			"external_controller": "0.0.0.0:9090"
		}
	},
	"dns": {
		"servers": [
			{
				"tag": "local-dns",
				"type": "local"
			},
			{
				"tag": "adguard-dns",
				"type": "udp",
				"server": "94.140.14.14",
				"server_port": 53
			},
			{
				"tag": "adguard-dns-family",
				"type": "udp",
				"server": "94.140.14.15",
				"server_port": 53
			}
		],
		"rules": [
			{
				"domain_suffix": [
					".ru"
				],
				"action": "route",
				"server": "local-dns"
			}
		],
		"cache_capacity": 8192,
		"independent_cache": true,
		"reverse_mapping": true,
		"final": "adguard-dns"
	},
	"inbounds": [
		{
			"tag": "REALITY",
			"type": "vless",
			"listen": "0.0.0.0",
			"listen_port": 6443,
			"tcp_multi_path": true,
			"tcp_fast_open": true,
			"users": [],
			"tls": {
				"enabled": true,
				"server_name": "REPLACE_WITH_SERVER_NAME_FROM_TTY",
				"reality": {
					"enabled": true,
					"handshake": {
						"server": "REPLACE_WITH_REALITY_SERVER_NAME_FROM_TTY",
						"server_port": 443
					},
					"private_key": "REPLACE_WITH_INSTALLER_GENERATED_REALITY_PRIVATE_KEY",
					"short_id": "REPLACE_WITH_INSTALLER_GENERATED_REALITY_SHORT_ID"
				}
			}
		}
	],
	"outbounds": [
		{
			"type": "direct",
			"tag": "direct"
		}
	],
	"endpoints": [
		{
			"type": "wireguard",
			"tag": "warp-out",
			"system": true,
			"mtu": 1280,
			"address": [
				"REPLACE_WITH_WGCF_IPV4_ADDRESS",
				"REPLACE_WITH_WGCF_IPV6_ADDRESS"
			],
			"private_key": "REPLACE_WITH_WGCF_PRIVATE_KEY",
			"peers": [
				{
					"address": "engage.cloudflareclient.com",
					"port": 2408,
					"public_key": "REPLACE_WITH_WGCF_PEER_PUBLIC_KEY",
					"allowed_ips": [
						"0.0.0.0/0",
						"::/0"
					]
				}
			]
		}
	],
	"route": {
		"rule_set": [
			{
				"type": "remote",
				"tag": "geosite-malware",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-malware.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geoip-malware",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-malware.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geosite-phishing",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-phishing.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geoip-phishing",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geoip-phishing.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geosite-cryptominers",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/Chocolate4U/Iran-sing-box-rules/rule-set/geosite-cryptominers.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "adguard",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/zacred0rryn/srs-custom/refs/heads/main/binary/adguard/AdGuardDNSFilter.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geosite-openai",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-openai.srs",
				"download_detour": "direct"
			},
			{
				"type": "remote",
				"tag": "geosite-netflix",
				"format": "binary",
				"url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-netflix.srs",
				"download_detour": "direct"
			},
			{
				"type": "inline",
				"tag": "dns-servers",
				"rules": [
					{
						"domain_regex": [
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+adguard-dns\\.com",
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)+cloudflare-dns\\.com"
						]
					},
					{
						"domain": [
							"dns.google",
							"one.one.one.one"
						]
					},
					{
						"ip_cidr": [
							"1.1.1.0/24",
							"1.0.0.0/24",
							"8.8.8.8/32",
							"8.8.4.4/32",
							"94.140.14.14/32",
							"94.140.15.15/32",
							"94.140.14.15/32",
							"94.140.15.16/32",
							"2a10:50c0::ad1:ff/128",
							"2a10:50c0::ad2:ff/128",
							"2a10:50c0::bad1:ff/128",
							"2a10:50c0::bad2:ff/128"
						]
					}
				]
			},
			{
				"type": "inline",
				"tag": "nxdomains",
				"rules": [
					{
						"ip_cidr": [
							"0.0.0.0/32",
							"10.10.34.34/32",
							"10.10.34.36/32",
							"10.10.36.36/32",
							"::/128",
							"2001:4188:2:600:10:10:34:36/128"
						]
					}
				]
			},
			{
				"type": "inline",
				"tag": "youtube",
				"rules": [
					{
						"domain_regex": [
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)*youtube\\.com",
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)*youtu\\.be",
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)*ytimg\\.com",
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)*ggpht\\.com",
							"(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\\.)*googlevideo\\.com"
						]
					},
					{
						"domain": [
							"youtube-ui.l.google.com",
							"youtubei.googleapis.com",
							"youtubei-ac.googleapis.com"
						]
					}
				]
			}
		],
		"rules": [
			{
				"action": "resolve",
				"server": "adguard-dns",
				"strategy": "prefer_ipv4"
			},
			{
				"action": "sniff",
				"sniffer": [
					"http",
					"tls",
					"dns",
					"quic"
				],
				"timeout": "1s"
			},
			{
				"protocol": "dns",
				"action": "hijack-dns"
			},
			{
				"rule_set": [
					"dns-servers"
				],
				"action": "route",
				"outbound": "direct"
			},
			{
				"rule_set": [
					"geosite-malware",
					"geosite-phishing",
					"geosite-cryptominers",
					"geoip-malware",
					"geoip-phishing",
					"adguard",
					"nxdomains"
				],
				"action": "reject"
			},
			{
				"rule_set": [
					"youtube"
				],
				"action": "route",
				"outbound": "direct"
			},
			{
				"rule_set": [
					"geosite-netflix"
				],
				"action": "route",
				"outbound": "warp-out"
			},
			{
				"rule_set": [
					"geosite-openai"
				],
				"action": "route",
				"outbound": "warp-out"
			}
		],
		"default_domain_resolver": {
			"server": "local-dns"
		},
		"final": "direct"
	}
}
